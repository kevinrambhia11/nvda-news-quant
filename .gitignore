# Python
__pycache__/
*.pyc
.venv/

# Credentials must never enter this (public) repo: no root-level JSON files
# (service-account keys etc.). Data JSONs live under artifacts/, already
# handled below.
/*.json

# Generated artifacts (recreated by `python main.py train` / `vol-train`)
artifacts/*
!artifacts/cache/
artifacts/cache/*

# Keep the GDELT history cache: it took a cross-network workaround to
# bootstrap (GDELT rate-limits some corporate IPs) and is only ~75 KB.
!artifacts/cache/gdelt_daily.csv

# Keep the verified earnings calendar (Yahoo rate-limits this network too)
!artifacts/cache/earnings_NVDA.csv

# Keep the intraday snapshots: Yahoo only serves 5-min bars for a rolling
# 60 days, so these cannot be re-downloaded later
!artifacts/cache/nvda_5m.csv
!artifacts/cache/qqq_5m.csv
!artifacts/cache/gdelt_15min.csv

# BigQuery-sourced series (rebuildable, but only with credentials)
!artifacts/cache/gdelt_competitors.csv
!artifacts/cache/gdelt_industry.csv
!artifacts/cache/bq_industry.csv

# Price cache: the hosted dashboard's Track record tab scores forecasts
# against realized opens, so it needs prices in the repo (public data;
# refreshed by the daily task's push)
!artifacts/cache/prices_NVDA.csv

# news2 archive backup: the LIVE parquet grows daily via news-topup, so
# committing it daily would add a 36 MB blob per day. Instead the weekly
# retrain copies it to *_backup.parquet (tracked); the live file stays
# untracked. Restore on a fresh clone: copy the backup over the live name -
# the next top-up re-pulls the missing days for pennies. Embeddings
# (~600 MB) stay local (rebuildable from the parquet in ~20 min).
!artifacts/cache/news2_daily.csv
!artifacts/cache/news2_features.csv
!artifacts/cache/news2_articles_backup.parquet

# Display artifacts for the hosted dashboard (Streamlit Community Cloud
# renders whatever the repo carries; push after retraining to refresh it)
!artifacts/*.txt
!artifacts/*.joblib
!artifacts/oos_predictions.csv
!artifacts/vol_oos_predictions.csv
!artifacts/equity_curve.csv
!artifacts/fused_equity.csv
!artifacts/intraday_events.csv
!artifacts/signal_*.json
!artifacts/vol_forecast_*.json

# Streamlit
.streamlit/

# Machine-specific scheduled-task wrappers and their log
scripts/
artifacts/scheduler.log
